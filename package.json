{
  "name": "pickle",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "emulators": "cross-env CI=true firebase emulators:start --only auth",
    "test:e2e": "cross-env CI=true firebase emulators:exec --only auth \"npm run test:e2e --workspace=@pickle/api\""
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "firebase-tools": "^15.23.0"
  }
}
