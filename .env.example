# Local docker-compose Postgres + Redis. Copy to .env (gitignored) and adjust as needed.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pickle
POSTGRES_PORT=5432

# Restricted runtime role created by docker/postgres-init/01-app-role.sh.
# Keep this in sync with apps/api/.env's DATABASE_URL password.
APP_DB_PASSWORD=pickle_app_dev_password

REDIS_PORT=6379
