# Copy to .env (gitignored) and adjust as needed. Values here match the
# defaults in the root .env.example used by docker-compose.

# Prisma Client (runtime) connects as the restricted pickle_app role: no
# UPDATE/DELETE on append-only tables (payments, payouts, refunds, booking_events).
DATABASE_URL="postgresql://pickle_app:pickle_app_dev_password@localhost:5432/pickle"

# prisma migrate / db push use this instead - the Postgres superuser, needed
# to create/alter tables. Never used by the running API.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/pickle"

REDIS_URL="redis://localhost:6379"

PORT=3000

# Points the Firebase Admin SDK at the local emulator instead of real
# Firebase. Matches firebase.json's auth emulator port. Unset entirely
# once a real Firebase project exists in a deployed environment.
FIREBASE_AUTH_EMULATOR_HOST="localhost:9099"
FIREBASE_PROJECT_ID="demo-pickle"
