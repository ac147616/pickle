// Data model per docs/PICKLE_SPEC.md §6. Sections below mirror that doc's own
// groupings. See CLAUDE.md for the hard invariants this schema encodes:
// append-only money/event tables, integer cents, progressive PII disclosure.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// No `url` here - Prisma 7 removed runtime connection strings from the schema
// file. Migrate/introspect use prisma.config.ts's datasource.url (DIRECT_URL,
// the migrator role); the runtime PrismaClient gets DATABASE_URL (the
// restricted pickle_app role) via a driver adapter - see prisma/client.ts.
datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  SHIPPER
  CARRIER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum OrgType {
  SHIPPER
  CARRIER
  BOTH
}

enum OrgMemberRole {
  OWNER
  DRIVER
  STAFF
}

enum VerificationDocType {
  LICENCE
  INSURANCE
  ID
  REGO
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DriverStatus {
  ACTIVE
  SUSPENDED
}

enum TripStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ShipmentStatus {
  DRAFT
  LISTED
  BOOKED
  COMPLETED
  CANCELLED
}

// Exact state machine from PICKLE_SPEC.md §5. Server-enforced transitions
// live in application code, not here - this just constrains the column.
enum BookingStatus {
  BOOKED
  DRIVER_EN_ROUTE
  ARRIVED_PICKUP
  PICKED_UP
  IN_TRANSIT
  ARRIVED_DROPOFF
  DELIVERED
  COMPLETED
  EXCEPTION_HOLD
  CANCELLED
}

enum ExceptionType {
  DAMAGE
  MISMATCH
  NO_SHOW
  OVERSIZE
  ACCESS
  OTHER
}

enum ExceptionStatus {
  OPEN
  RESOLVED
}

enum PaymentStatus {
  REQUIRES_CAPTURE
  CAPTURED
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

enum RefundStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
}

// ---------------------------------------------------------------------------
// Identity & organisations
// ---------------------------------------------------------------------------

model User {
  id          String     @id @default(uuid()) @db.Uuid
  firebaseUid String     @unique @map("firebase_uid")
  email       String?    @unique
  phone       String?    @unique
  fullName    String     @map("full_name")
  role        UserRole
  status      UserStatus @default(ACTIVE)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  organisationMemberships OrganisationMember[]
  drivers                 Driver[]
  reviewedDocuments       VerificationDocument[] @relation("DocumentReviewer")
  ownedDocuments          VerificationDocument[] @relation("DocumentOwnerUser")
  shipments               Shipment[]             @relation("ShipmentShipperUser")
  bookingEvents           BookingEvent[]
  cancelledBookings       Booking[]              @relation("BookingCancelledBy")
  raisedExceptions        Exception[]            @relation("ExceptionRaisedBy")
  resolvedExceptions      Exception[]            @relation("ExceptionResolvedBy")
  ratingsGiven            Rating[]               @relation("RatingRater")
  ratingsReceived         Rating[]               @relation("RatingRateeUser")
  disputesOpened          Dispute[]              @relation("DisputeOpenedBy")
  messagesSent            Message[]

  @@map("users")
}

model Organisation {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  nzbn       String?   @unique
  type       OrgType
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  members         OrganisationMember[]
  ownedDocuments  VerificationDocument[] @relation("DocumentOwnerOrg")
  drivers         Driver[]
  vehicles        Vehicle[]
  trips           Trip[]
  shipments       Shipment[]             @relation("ShipmentShipperOrg")
  ratingsReceived Rating[]               @relation("RatingRateeOrg")
  payoutsReceived Payout[]

  @@map("organisations")
}

model OrganisationMember {
  id             String        @id @default(uuid()) @db.Uuid
  organisationId String        @map("org_id") @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  memberRole     OrgMemberRole @map("member_role")
  createdAt      DateTime      @default(now()) @map("created_at")

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organisationId, userId])
  @@map("organisation_members")
}

// ---------------------------------------------------------------------------
// Verification
// ---------------------------------------------------------------------------

// owner is exactly one of a user (e.g. a driver's licence) or an organisation
// (e.g. fleet insurance) - enforced by a CHECK constraint in the migration.
model VerificationDocument {
  id          String              @id @default(uuid()) @db.Uuid
  ownerUserId String?             @map("owner_user_id") @db.Uuid
  ownerOrgId  String?             @map("owner_org_id") @db.Uuid
  docType     VerificationDocType @map("doc_type")
  storagePath String              @map("storage_path")
  status      VerificationStatus  @default(PENDING)
  reviewedBy  String?             @map("reviewed_by") @db.Uuid
  reviewedAt  DateTime?           @map("reviewed_at")
  expiresAt   DateTime?           @map("expires_at")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  ownerUser           User?         @relation("DocumentOwnerUser", fields: [ownerUserId], references: [id], onDelete: Restrict)
  ownerOrg            Organisation? @relation("DocumentOwnerOrg", fields: [ownerOrgId], references: [id], onDelete: Restrict)
  reviewer            User?         @relation("DocumentReviewer", fields: [reviewedBy], references: [id])
  vehicleInsuranceFor Vehicle[]     @relation("VehicleInsuranceDoc")

  @@index([status])
  @@index([expiresAt])
  @@map("verification_documents")
}

model Driver {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  organisationId String       @map("org_id") @db.Uuid
  licenceClass   String       @map("licence_class")
  licenceExpiry  DateTime     @map("licence_expiry")
  status         DriverStatus @default(ACTIVE)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id])
  organisation Organisation @relation(fields: [organisationId], references: [id])
  trips        Trip[]

  @@index([organisationId])
  @@map("drivers")
}

// ---------------------------------------------------------------------------
// Fleet & trips
// ---------------------------------------------------------------------------

model Vehicle {
  id             String   @id @default(uuid()) @db.Uuid
  organisationId String   @map("org_id") @db.Uuid
  rego           String   @unique
  makeModel      String   @map("make_model")
  bodyType       String   @map("body_type")
  maxVolumeM3    Decimal  @map("max_volume_m3") @db.Decimal(8, 2)
  maxWeightKg    Decimal  @map("max_weight_kg") @db.Decimal(8, 2)
  enclosed       Boolean  @default(false)
  insuranceDocId String?  @map("insurance_doc_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organisation Organisation          @relation(fields: [organisationId], references: [id])
  insuranceDoc VerificationDocument? @relation("VehicleInsuranceDoc", fields: [insuranceDocId], references: [id])
  trips        Trip[]

  @@index([organisationId])
  @@map("vehicles")
}

// geog is derived from lat/lng by a DB trigger (see migration) so the two can
// never drift - application code should only ever read/write lat/lng.
model Address {
  id        String                                  @id @default(uuid()) @db.Uuid
  formatted String
  lat       Float?
  lng       Float?
  geog      Unsupported("geography(Point, 4326)")?
  placeId   String?                                 @map("place_id")
  validated Boolean                                 @default(false)
  notes     String?
  createdAt DateTime                                @default(now()) @map("created_at")
  updatedAt DateTime                                @updatedAt @map("updated_at")

  tripsOrigin      Trip[]     @relation("TripOriginAddress")
  tripsDestination Trip[]     @relation("TripDestinationAddress")
  shipmentsPickup  Shipment[] @relation("ShipmentPickupAddress")
  shipmentsDropoff Shipment[] @relation("ShipmentDropoffAddress")

  @@map("addresses")
}

model Trip {
  id                   String                                  @id @default(uuid()) @db.Uuid
  organisationId       String                                  @map("org_id") @db.Uuid
  driverId             String?                                 @map("driver_id") @db.Uuid
  vehicleId            String                                  @map("vehicle_id") @db.Uuid
  originAddressId      String                                  @map("origin_address_id") @db.Uuid
  destinationAddressId String                                  @map("destination_address_id") @db.Uuid
  originLat            Float?                                  @map("origin_lat")
  originLng            Float?                                  @map("origin_lng")
  originGeog           Unsupported("geography(Point, 4326)")?  @map("origin_geog")
  destinationLat       Float?                                  @map("destination_lat")
  destinationLng       Float?                                  @map("destination_lng")
  destinationGeog      Unsupported("geography(Point, 4326)")?  @map("destination_geog")
  departureWindowStart DateTime                                @map("departure_window_start")
  departureWindowEnd   DateTime                                @map("departure_window_end")
  routePolyline        String?                                 @map("route_polyline")
  availableVolumeM3    Decimal                                 @map("available_volume_m3") @db.Decimal(8, 2)
  availableWeightKg    Decimal                                 @map("available_weight_kg") @db.Decimal(8, 2)
  acceptedCategories   String[]                                @map("accepted_categories")
  status               TripStatus                              @default(DRAFT)
  recurrenceRule       String?                                 @map("recurrence_rule")
  createdAt            DateTime                                @default(now()) @map("created_at")
  updatedAt            DateTime                                @updatedAt @map("updated_at")

  organisation       Organisation @relation(fields: [organisationId], references: [id])
  driver             Driver?      @relation(fields: [driverId], references: [id])
  vehicle            Vehicle      @relation(fields: [vehicleId], references: [id])
  originAddress      Address      @relation("TripOriginAddress", fields: [originAddressId], references: [id])
  destinationAddress Address      @relation("TripDestinationAddress", fields: [destinationAddressId], references: [id])
  bookings           Booking[]

  @@index([organisationId])
  @@index([status])
  @@map("trips")
}

// ---------------------------------------------------------------------------
// Shipments
// ---------------------------------------------------------------------------

// shipper is exactly one of an organisation (business lane) or a user
// (individual lane) - enforced by a CHECK constraint in the migration.
model Shipment {
  id                 String         @id @default(uuid()) @db.Uuid
  shipperOrgId       String?        @map("shipper_org_id") @db.Uuid
  shipperUserId      String?        @map("shipper_user_id") @db.Uuid
  pickupAddressId    String         @map("pickup_address_id") @db.Uuid
  dropoffAddressId   String         @map("dropoff_address_id") @db.Uuid
  readyFrom          DateTime       @map("ready_from")
  deliverBy          DateTime       @map("deliver_by")
  declaredValueCents Int            @map("declared_value_cents")
  notes              String?
  status             ShipmentStatus @default(DRAFT)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  shipperOrg     Organisation?  @relation("ShipmentShipperOrg", fields: [shipperOrgId], references: [id], onDelete: Restrict)
  shipperUser    User?          @relation("ShipmentShipperUser", fields: [shipperUserId], references: [id], onDelete: Restrict)
  pickupAddress  Address        @relation("ShipmentPickupAddress", fields: [pickupAddressId], references: [id])
  dropoffAddress Address        @relation("ShipmentDropoffAddress", fields: [dropoffAddressId], references: [id])
  items          ShipmentItem[]
  bookings       Booking[]

  @@index([shipperOrgId])
  @@index([shipperUserId])
  @@index([status])
  @@map("shipments")
}

model ShipmentItem {
  id            String   @id @default(uuid()) @db.Uuid
  shipmentId    String   @map("shipment_id") @db.Uuid
  cargoCategory String   @map("cargo_category")
  packagingType String   @map("packaging_type")
  qty           Int
  weightKg      Decimal  @map("weight_kg") @db.Decimal(8, 2)
  lengthCm      Decimal  @map("length_cm") @db.Decimal(8, 2)
  widthCm       Decimal  @map("width_cm") @db.Decimal(8, 2)
  heightCm      Decimal  @map("height_cm") @db.Decimal(8, 2)
  photos        Json     @default("[]")
  createdAt     DateTime @default(now()) @map("created_at")

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("shipment_items")
}

// ---------------------------------------------------------------------------
// Bookings & events
// ---------------------------------------------------------------------------

model Booking {
  id                 String        @id @default(uuid()) @db.Uuid
  shipmentId         String        @map("shipment_id") @db.Uuid
  tripId             String        @map("trip_id") @db.Uuid
  quotedPriceCents   Int           @map("quoted_price_cents")
  platformFeeCents   Int           @map("platform_fee_cents")
  carrierPayoutCents Int           @map("carrier_payout_cents")
  status             BookingStatus @default(BOOKED)
  pickupQrToken      String        @unique @map("pickup_qr_token")
  deliveryCode       String        @map("delivery_code")
  cancelledBy        String?       @map("cancelled_by") @db.Uuid
  cancellationReason String?       @map("cancellation_reason")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  shipment        Shipment       @relation(fields: [shipmentId], references: [id])
  trip            Trip           @relation(fields: [tripId], references: [id])
  cancelledByUser User?          @relation("BookingCancelledBy", fields: [cancelledBy], references: [id])
  events          BookingEvent[]
  podRecord       PodRecord?
  exceptions      Exception[]
  payments        Payment[]
  payouts         Payout[]
  ratings         Rating[]
  disputes        Dispute[]
  messages        Message[]

  @@index([shipmentId])
  @@index([tripId])
  @@index([status])
  @@map("bookings")
}

// APPEND-ONLY: every status change, scan, photo, exception, delay gets a row.
// UPDATE/DELETE are revoked at the DB level for the runtime role (migration).
model BookingEvent {
  id          String                                  @id @default(uuid()) @db.Uuid
  bookingId   String                                  @map("booking_id") @db.Uuid
  eventType   String                                  @map("event_type")
  actorUserId String?                                 @map("actor_user_id") @db.Uuid
  occurredAt  DateTime                                @default(now()) @map("occurred_at")
  lat         Float?
  lng         Float?
  geog        Unsupported("geography(Point, 4326)")?
  metadata    Json                                    @default("{}")

  booking Booking @relation(fields: [bookingId], references: [id])
  actor   User?   @relation(fields: [actorUserId], references: [id])

  @@index([bookingId])
  @@map("booking_events")
}

// ---------------------------------------------------------------------------
// POD & exceptions
// ---------------------------------------------------------------------------

model PodRecord {
  id            String                                  @id @default(uuid()) @db.Uuid
  bookingId     String                                  @unique @map("booking_id") @db.Uuid
  recipientName String?                                 @map("recipient_name")
  signaturePath String?                                 @map("signature_path")
  photoPaths    Json                                    @default("[]") @map("photo_paths")
  lat           Float?
  lng           Float?
  geog          Unsupported("geography(Point, 4326)")?
  capturedAt    DateTime                                @map("captured_at")
  deviceInfo    Json                                    @default("{}") @map("device_info")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("pod_records")
}

model Exception {
  id          String          @id @default(uuid()) @db.Uuid
  bookingId   String          @map("booking_id") @db.Uuid
  raisedBy    String          @map("raised_by") @db.Uuid
  type        ExceptionType
  description String?
  photoPaths  Json            @default("[]") @map("photo_paths")
  status      ExceptionStatus @default(OPEN)
  resolvedBy  String?         @map("resolved_by") @db.Uuid
  resolution  String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  booking        Booking @relation(fields: [bookingId], references: [id])
  raisedByUser   User    @relation("ExceptionRaisedBy", fields: [raisedBy], references: [id])
  resolvedByUser User?   @relation("ExceptionResolvedBy", fields: [resolvedBy], references: [id])

  @@index([bookingId])
  @@map("exceptions")
}

// ---------------------------------------------------------------------------
// Payments (APPEND-ONLY: integer cents, Stripe ids, idempotency keys).
// UPDATE/DELETE are revoked at the DB level for the runtime role (migration).
// ---------------------------------------------------------------------------

model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  bookingId             String        @map("booking_id") @db.Uuid
  amountCents           Int           @map("amount_cents")
  currency              String        @default("NZD")
  stripePaymentIntentId String        @unique @map("stripe_payment_intent_id")
  status                PaymentStatus
  idempotencyKey        String        @unique @map("idempotency_key")
  createdAt             DateTime      @default(now()) @map("created_at")

  booking Booking  @relation(fields: [bookingId], references: [id])
  refunds Refund[]

  @@index([bookingId])
  @@map("payments")
}

model Payout {
  id               String       @id @default(uuid()) @db.Uuid
  bookingId        String       @map("booking_id") @db.Uuid
  carrierOrgId     String       @map("carrier_org_id") @db.Uuid
  amountCents      Int          @map("amount_cents")
  currency         String       @default("NZD")
  stripeTransferId String?      @unique @map("stripe_transfer_id")
  status           PayoutStatus @default(PENDING)
  idempotencyKey   String       @unique @map("idempotency_key")
  createdAt        DateTime     @default(now()) @map("created_at")

  booking    Booking      @relation(fields: [bookingId], references: [id])
  carrierOrg Organisation @relation(fields: [carrierOrgId], references: [id])

  @@index([bookingId])
  @@index([carrierOrgId])
  @@map("payouts")
}

model Refund {
  id             String       @id @default(uuid()) @db.Uuid
  paymentId      String       @map("payment_id") @db.Uuid
  amountCents    Int          @map("amount_cents")
  reason         String?
  stripeRefundId String?      @unique @map("stripe_refund_id")
  status         RefundStatus @default(PENDING)
  idempotencyKey String       @unique @map("idempotency_key")
  createdAt      DateTime     @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@map("refunds")
}

// ---------------------------------------------------------------------------
// Ratings & disputes
// ---------------------------------------------------------------------------

// ratee is exactly one of an organisation or a user (individual shippers have
// no org) - enforced by a CHECK constraint in the migration. One rating per
// rater per booking.
model Rating {
  id          String   @id @default(uuid()) @db.Uuid
  bookingId   String   @map("booking_id") @db.Uuid
  raterUserId String   @map("rater_user_id") @db.Uuid
  rateeOrgId  String?  @map("ratee_org_id") @db.Uuid
  rateeUserId String?  @map("ratee_user_id") @db.Uuid
  stars       Int
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")

  booking   Booking       @relation(fields: [bookingId], references: [id])
  rater     User          @relation("RatingRater", fields: [raterUserId], references: [id])
  rateeOrg  Organisation? @relation("RatingRateeOrg", fields: [rateeOrgId], references: [id], onDelete: Restrict)
  rateeUser User?         @relation("RatingRateeUser", fields: [rateeUserId], references: [id], onDelete: Restrict)

  @@unique([bookingId, raterUserId])
  @@map("ratings")
}

model Dispute {
  id         String        @id @default(uuid()) @db.Uuid
  bookingId  String        @map("booking_id") @db.Uuid
  openedBy   String        @map("opened_by") @db.Uuid
  category   String
  status     DisputeStatus @default(OPEN)
  outcome    String?
  adminNotes String?       @map("admin_notes")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  booking      Booking @relation(fields: [bookingId], references: [id])
  openedByUser User    @relation("DisputeOpenedBy", fields: [openedBy], references: [id])

  @@index([bookingId])
  @@map("disputes")
}

// ---------------------------------------------------------------------------
// Messaging (chat scoped to a booking)
// ---------------------------------------------------------------------------

model Message {
  id           String   @id @default(uuid()) @db.Uuid
  bookingId    String   @map("booking_id") @db.Uuid
  senderUserId String   @map("sender_user_id") @db.Uuid
  body         String
  sentAt       DateTime @default(now()) @map("sent_at")

  booking Booking @relation(fields: [bookingId], references: [id])
  sender  User    @relation(fields: [senderUserId], references: [id])

  @@index([bookingId])
  @@map("messages")
}
